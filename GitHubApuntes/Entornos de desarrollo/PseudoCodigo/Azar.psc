Algoritmo sin_titulo
	
	//simular 100 tiradas de 2 dados y contar las veces que entre los 2 suman 10 3 al 12
	//y mostrar por pantalla la suma de todos los numeros
	
	sumanumeros= 0
	
	Para i = 0 Hasta 10 Con Paso 1 Hacer
		numeroaleatorio1 = azar(9)+3

		

		
		sumanumeros = sumanumeros + numeroaleatorio1
		
	Fin Para
	
	Escribir sumanumeros
	
FinAlgoritmo
